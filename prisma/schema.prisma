generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- ENUMS ---

enum PlanType {
  FREE
  PRO
  EXPIRED
}

enum OrderStatus {
  PRESUPUESTADO
  CONFIRMADO
  EN_PROCESO
  LISTO
  ENTREGADO
  CANCELADO
  RECHAZADO // Nuevo: Para que el dueño pueda cancelar pedidos de la web
}

enum DeliveryMethod {
  PICKUP      // Retiro por taller
  LOCAL       // Envío local (precio fijo definido por el usuario)
  NATIONWIDE  // Envío a todo el país (a convenir)
}

// --- MODELOS ---

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?   // Nombre del emprendimiento
  phone              String?   
  logoUrl            String?
  createdAt          DateTime  @default(now())
  
  // --- CONFIGURACIÓN DE TIENDA PÚBLICA ---
  slug               String?   @unique // URL: koda-maker.app/v/syg-creaciones
  isStoreActive      Boolean   @default(false)
  storeDescription   String?   @db.Text
  localShippingCost  Float     @default(0)
  allowPickup        Boolean   @default(true)
  allowNationwide    Boolean   @default(true)

  // --- SISTEMA DE SUSCRIPCIÓN SaaS ---
  plan               PlanType  @default(FREE)
  subscriptionId     String?   
  customerMpId       String?   
  validUntil         DateTime? 
  
  // Relaciones
  materials          Material[]
  templates          ProductTemplate[]
  orders             Order[]
  purchases          Purchase[]
  notifications      Notification[]
  pushSubscriptions  PushSubscription[]
}

model Material {
  id           String   @id @default(cuid())
  name         String
  type         String   // Láser, 3D, Insumo, Máquina
  unit         String   // gr, m, un, min
  unitPrice    Float    
  stock        Float    @default(0)
  minStock     Float    @default(0)
  
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  templates    TemplateMaterial[]
  purchases    Purchase[]
}

model ProductTemplate {
  id             String   @id @default(cuid())
  name           String
  category       String
  basePrice      Float    
  targetMargin   Float    @default(50) 
  machineTimeMin Int      @default(0)

  // --- CONFIGURACIÓN E-COMMERCE ---
  isPublic          Boolean @default(false)
  publicDescription String? @db.Text
  publicImage       String? // Imagen de portada para la tienda
  images         TemplateImage[] 

  userId         String
  user           User     @relation(fields: [userId], references: [id])
  
  materials      TemplateMaterial[]
  orderItems     OrderItem[]
}

model TemplateImage {
  id         String          @id @default(cuid())
  url        String
  template   ProductTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String
}


model TemplateMaterial {
  id         String          @id @default(cuid())
  quantity   Float           
  
  template   ProductTemplate @relation(fields: [templateId], references: [id])
  templateId String
  material   Material        @relation(fields: [materialId], references: [id])
  materialId String
}

model Order {
  id             String      @id @default(cuid())
  orderNumber    Int         @unique @default(autoincrement())
  customerName   String
  customerPhone  String?     
  status         OrderStatus @default(PRESUPUESTADO)
  createdAt      DateTime    @default(now())
  deliveryDate   DateTime?
  totalCost      Float       @default(0)
  totalPrice     Float       @default(0)
  designDetails  String?     
  notes          String?
  pickupTime      String?   
  trackingUrl     String?
  
  // --- DATOS DE LOGÍSTICA ---
  deliveryMethod DeliveryMethod @default(PICKUP)
  shippingCost   Float          @default(0)
  shippingAddress String?       @db.Text
  isFromStore    Boolean        @default(false) // Para saber si vino de la web pública

  userId         String
  user           User        @relation(fields: [userId], references: [id])
  
  items          OrderItem[]
  payments       Payment[]   
  images         OrderImage[]
}

model OrderImage {
  id      String @id @default(cuid())
  url     String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String
}

model OrderItem {
  id           String          @id @default(cuid())
  quantity     Int
  customPrice  Float           
  
  order        Order           @relation(fields: [orderId], references: [id])
  orderId      String
  template     ProductTemplate @relation(fields: [templateId], references: [id])
  templateId   String
}

model Payment {
  id        String   @id @default(cuid())
  amount    Float
  date      DateTime @default(now())
  method    String   
  
  order     Order    @relation(fields: [orderId], references: [id])
  orderId   String
}

model Purchase {
  id          String   @id @default(cuid())
  quantity    Float    
  unitPrice   Float    
  totalAmount Float    
  createdAt   DateTime @default(now())

  materialId  String
  material    Material @relation(fields: [materialId], references: [id])
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}