generator client {
  provider = "prisma-client-js"
  previewFeatures = ["relationJoins"] // <--- AGREGÁ ESTA LÍNEA

}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- MODELO DE USUARIO (SaaS Ready) ---

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  logoUrl       String?   
  createdAt     DateTime  @default(now())
  
  // Relaciones
  materials     Material[]
  templates     ProductTemplate[]
  orders        Order[]
  purchases     Purchase[] 
  notifications Notification[]

}
model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   // 'STOCK', 'DELIVERY', 'PAYMENT'
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}


model Purchase {
  id          String   @id @default(cuid())
  quantity    Float    
  unitPrice   Float    
  totalAmount Float    
  createdAt   DateTime @default(now())

  materialId  String
  material    Material @relation(fields: [materialId], references: [id])
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}


// --- MATERIALES ---

model Material {
  id           String   @id @default(cuid())
  name         String
  type         String   // Láser, 3D, Insumo, etc.
  unit         String   // gr, m, unidad, min
  unitPrice    Float    // Costo de compra por unidad
  stock        Float    @default(0)
  minStock     Float    @default(0)
  
  // Relación con Usuario
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  // Relación con Plantillas
  templates    TemplateMaterial[]
  purchases    Purchase[]
}

// --- PLANTILLAS DE PRODUCTOS (Recetas) ---

model ProductTemplate {
  id             String   @id @default(cuid())
  name           String
  category       String
  basePrice      Float    // Este será el "Precio Final" que ellos elijan
  targetMargin   Float    @default(50) // Porcentaje de ganancia deseado (ej: 50%)
  machineTimeMin Int      // Tiempo estimado de uso de máquina
  
  // Relación con Usuario
  userId         String
  user         User     @relation(fields: [userId], references: [id])
  
  // Relaciones
  materials      TemplateMaterial[]
  orderItems     OrderItem[]
}

// Relación muchos a muchos: Materiales usados en una plantilla
model TemplateMaterial {
  id         String          @id @default(cuid())
  quantity   Float           // Cantidad que consume de este material
  
  template   ProductTemplate @relation(fields: [templateId], references: [id])
  templateId String
  material   Material        @relation(fields: [materialId], references: [id])
  materialId String
}

// --- PEDIDOS ---

model Order {
  id             String      @id @default(cuid())
  orderNumber    Int         @unique @default(autoincrement())
  customerName   String
  customerPhone  String?     // Nuevo: Teléfono
  status         OrderStatus @default(PRESUPUESTADO)
  createdAt      DateTime    @default(now())
  deliveryDate   DateTime?
  totalCost      Float       @default(0)
  totalPrice     Float       @default(0)
  designDetails  String?     // Nuevo: Qué se graba/imprime
  images         OrderImage[] 
  notes          String?
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  items          OrderItem[]
  payments       Payment[]   
}

model OrderImage {
  id      String @id @default(cuid())
  url     String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String
}

// Items específicos dentro de un pedido
model OrderItem {
  id           String          @id @default(cuid())
  quantity     Int
  customPrice  Float           // Precio final pactado por unidad
  
  order        Order           @relation(fields: [orderId], references: [id])
  orderId      String
  template     ProductTemplate @relation(fields: [templateId], references: [id])
  templateId   String
}

// Registro de pagos (Señas / Pagos totales)
model Payment {
  id        String   @id @default(cuid())
  amount    Float
  date      DateTime @default(now())
  method    String   // Efectivo, Transferencia, etc.
  
  order     Order    @relation(fields: [orderId], references: [id])
  orderId   String
}

enum OrderStatus {
  PRESUPUESTADO
  CONFIRMADO
  EN_PROCESO
  LISTO
  ENTREGADO
  CANCELADO
}